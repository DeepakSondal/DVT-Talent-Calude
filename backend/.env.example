# 🛰️ DVT TALENT AI — ENVIRONMENT CONFIGURATION (v1.1)

# ── APP SETTINGS ────────────────────────────────────────────────────────────
APP_NAME="DVT Talent AI"
APP_ENV=development
SECRET_KEY=generate-a-secure-key-for-production
DATABASE_URL=sqlite+aiosqlite:///./dvt_talent.db
DATABASE_SYNC_URL=sqlite:///./dvt_talent.db
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── AI AGENT MODELS (PYDANTIC AI) ──────────────────────────────────────────
# Priority: Anthropic > Groq > OpenAI > Kimi > DeepSeek

# Anthropic (Recommended for Discovery/Critic)
ANTHROPIC_API_KEY=sk-ant-...

# Groq (Recommended for High-Speed Sourcing)
GROQ_API_KEY=gsk_...

# OpenAI (Fallback)
OPENAI_API_KEY=sk-...

# DeepSeek (Reasoning)
DEEPSEEK_API_KEY=sk-...

# ── SEARCH & TOOLS ──────────────────────────────────────────────────────────
SERPER_API_KEY=your_serper_key
GITHUB_TOKEN=your_github_token
APIFY_API_KEY=your_apify_key

# ── INFRASTRUCTURE ─────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8001

# ── EMAIL & COMMUNICATIONS ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
