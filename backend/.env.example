# ============================================================
# DVT Talent AI — Backend Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# App
APP_NAME="DVT Talent AI"
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
POSTGRES_DB=dvt_talent
POSTGRES_USER=dvt_user
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
DATABASE_SYNC_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_RESUMES=dvt_resumes
CHROMA_COLLECTION_JOBS=dvt_jobs
CHROMA_COLLECTION_COMPANIES=dvt_companies

# AI Models — Kimi API (Primary)
KIMI_API_KEY=your-kimi-api-key
KIMI_API_BASE=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-128k

# AI Models — DeepSeek (Secondary)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenAI (Fallback)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# Search
SERPER_API_KEY=your-serper-api-key

# Scraping
APIFY_API_KEY=your-apify-api-key

# Email — Gmail API
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_SENDER_EMAIL=your-email@gmail.com

# GitHub (for candidate sourcing)
GITHUB_TOKEN=your-github-personal-access-token

# App base URL (used for email tracking pixels and webhooks)
APP_BASE_URL=http://localhost:8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Logging
LOG_LEVEL=INFO
