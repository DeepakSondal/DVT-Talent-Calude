# ============================================================
# DVT Talent AI — Backend Environment Configuration Example
# ============================================================
# Copy this file to .env and update the values.

# APP
APP_NAME="DVT Talent AI"
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# DATABASE
POSTGRES_DB=dvt_talent
POSTGRES_USER=dvt_user
POSTGRES_PASSWORD=dvt_password
# Local: postgresql+asyncpg://dvt_user:dvt_password@localhost:5432/dvt_talent
# Docker: postgresql+asyncpg://dvt_user:dvt_password@postgres:5432/dvt_talent
DATABASE_URL=postgresql+asyncpg://dvt_user:dvt_password@postgres:5432/dvt_talent
DATABASE_SYNC_URL=postgresql://dvt_user:dvt_password@postgres:5432/dvt_talent

# REDIS
# Local: redis://localhost:6379/0
# Docker: redis://redis:6379/0
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# CHROMADB
# Local: localhost
# Docker: chromadb
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_RESUMES=dvt_resumes
CHROMA_COLLECTION_JOBS=dvt_jobs
CHROMA_COLLECTION_COMPANIES=dvt_companies

# AI MODELS — API KEYS
# At least one key is required for agents to function.
KIMI_API_KEY=
KIMI_API_BASE=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-128k

DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Groq (Recommended for speed)
# Use your Groq API key here
GROQ_API_KEY=
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-70b-versatile

# OpenAI (Fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# SEARCH
# Required for Lead Discovery and Market Intelligence agents
SERPER_API_KEY=

# SCRAPING
APIFY_API_KEY=

# EMAIL — GMAIL API
# See generate_token.py to get these values
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=

# SOCIAL AUTH (OAuth2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# GITHUB TOKEN (For candidate sourcing)
GITHUB_TOKEN=

# APP BASE URL
APP_BASE_URL=http://localhost:8000

# RATE LIMITING
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# LOGGING
LOG_LEVEL=INFO
