# DVT Talent AI — Frontend Environment Variables
# Copy to .env.local and update values

# API URL (backend FastAPI server)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# WebSocket URL (for live agent activity feed)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/ws/live

# App name (shown in browser tab and header)
NEXT_PUBLIC_APP_NAME=DVT Talent AI
